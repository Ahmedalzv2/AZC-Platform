//@version=6
// =====================================================================
// AZC Combined Trading Suite
// =====================================================================
// Single indicator merging five modules behind master toggles.
//
// Module attribution and licensing:
//   1. ICT Toolkit module      — adapted from "dmn's ICT Toolkit" © fxdmn
//                                (Mozilla Public License 2.0)
//   2. Liquidity Delta module  — adapted from "Liquidity Delta Profiler"
//                                © LuxAlgo (CC BY-NC-SA 4.0).
//                                This combined work is also CC BY-NC-SA 4.0
//                                for the Liquidity Delta module portion.
//   3. Ichimoku module         — fresh implementation of the public
//                                Ichimoku Kinko Hyo system (Goichi Hosoda)
//                                with layered TK-cross signal categories.
//   4. Silver Context module   — fresh implementation of a trend-EMA +
//                                macro-stress (DXY/US10Y EMA breakout) +
//                                volatility-flush (ATR / % move) gate.
//                                Silver-specific; off by default.
//   5. Multi-TF FVG module     — fresh implementation of the public ICT
//                                3-candle Fair Value Gap pattern with
//                                higher-TF support and mitigation tracking.
//
// The two original strategies that inspired modules 3 and 4 are converted
// to indicator visuals + alertconditions (Pine permits only one strategy()
// per script). A simulated position state drives SL/TP line drawing.
// =====================================================================

indicator("AZC Combined ICT/Ichimoku/Silver/Liquidity/FVG",
     shorttitle="AZC Suite",
     overlay=true,
     max_lines_count=500,
     max_boxes_count=500,
     max_labels_count=500)

// =====================================================================
// MASTER MODULE TOGGLES
// =====================================================================
var string gMaster = "Master Toggles"
useIchimoku  = input.bool(true,  "Ichimoku",        group=gMaster)
useSilver    = input.bool(false, "Silver Context",  group=gMaster, tooltip="Silver-specific: gates on DXY/US10Y. Disable on non-precious-metals charts.")
useLiquidity = input.bool(true,  "Liquidity Delta", group=gMaster)
useIct       = input.bool(true,  "ICT Toolkit",     group=gMaster)
useFvg       = input.bool(true,  "Multi-TF FVG",    group=gMaster)

// =====================================================================
// SHARED HELPERS
// =====================================================================
var int   DECIMALS = int(math.log10(1/syminfo.mintick))
var float PIP      = math.pow(10, DECIMALS - 1)

// ICT helpers (kept in original form for ICT Toolkit module compatibility)
hours(int h, int m=0) =>
    time + (3600000 * h) + (60000 * m)

stringToHour(string s)    => math.round(str.tonumber(str.substring(s, 0, 2)))
stringToMinutes(string s) => math.round(str.tonumber(str.substring(s, 2, 4)))

averageRange(float h, float l, int n) =>
    float r = 0.0
    for i = 1 to n
        r += h[i] - l[i]
    PIP * r / n

addLines(array<line> a, int x1, int x2, float y, color c, int n, string s, int w) =>
    for i = 0 to n - 1
        array.push(a, line.new(x1, y, x2, y, xloc=xloc.bar_time, color=c, style=s, width=w))

delLines(array<line> a) =>
    if array.size(a) > 0
        for i = 0 to array.size(a) - 1
            line.delete(array.get(a, i))

setLineArrayY(array<line> a, float y, float spacing, int m) =>
    for [i, l] in a
        float step = (i + 1) * spacing * m
        line.set_y1(l, y + step)
        line.set_y2(l, y + step)

lineset_y(line l, float y) =>
    line.set_y1(l, y)
    line.set_y2(l, y)

inSession(string sessionTime, string sessionTimeZone=syminfo.timezone) =>
    not na(time(timeframe.period, sessionTime, sessionTimeZone))

getBrightness(color c) =>
    r = color.r(c)
    g = color.g(c)
    b = color.b(c)
    math.sqrt(r*r*0.241 + g*g*0.691 + b*b*0.068)

blackOrWhiteText(color c) => getBrightness(c) > 130 ? color.black : color.white

getLineStyle(string s) =>
    switch s
        "Solid"  => line.style_solid
        "Dotted" => line.style_dotted
        "Dashed" => line.style_dashed

// Shared 14-period ATR (used by Silver flush logic and LuxAlgo zone sizing)
float atr14 = ta.atr(14)

f_persist(bool cond, int bars) =>
    bool ok = true
    for i = 0 to bars - 1
        ok := ok and cond[i] == true
    ok


// =====================================================================
// MODULE 3: ICHIMOKU
// Fresh implementation of public Ichimoku Kinko Hyo with layered signals
// =====================================================================
var string gIch     = "Ichimoku"
var string gIchSig  = "Ichimoku · Signal Filters"
var string gIchRisk = "Ichimoku · Risk Management"

tenkanPeriod      = input.int(9,  "Tenkan-Sen Period",    minval=1, group=gIch)
kijunPeriod       = input.int(26, "Kijun-Sen Period",     minval=1, group=gIch)
senkouSpanBPeriod = input.int(52, "Senkou Span B Period", minval=1, group=gIch)
displacement      = input.int(26, "Displacement",         minval=1, group=gIch)

useCloudFilter        = input.bool(true,  "Cloud Position Filter",            group=gIchSig)
useChikouConfirmation = input.bool(true,  "Chikou Span Confirmation",         group=gIchSig)
strongSignalsOnly     = input.bool(false, "Strong Signals Only",              group=gIchSig, tooltip="Require price above/below cloud")
multiSignalDisplay    = input.bool(true,  "Show Multiple Signal Layers",      group=gIchSig)

useSL          = input.bool(true,  "Use Stop Loss", group=gIchRisk)
slType         = input.string("Recent Low/High", "Stop Loss Type", options=["Kijun-Sen", "Recent Low/High", "Percentage", "Trailing Low"], group=gIchRisk)
slPercent      = input.float(2.0,  "Stop Loss %",              minval=0.1, maxval=10, step=0.1,  group=gIchRisk)
slOffset       = input.float(0.1,  "SL Offset %",              minval=0,   maxval=2,  step=0.05, group=gIchRisk)
recentLookback = input.int(10,     "Recent Low/High Lookback", minval=5,   maxval=50, step=1,    group=gIchRisk)
useTP          = input.bool(true,  "Use Take Profit",                                            group=gIchRisk)
tpRatio        = input.float(2.0,  "Risk/Reward Ratio",        minval=0.5, maxval=10, step=0.5,  group=gIchRisk)
trailingStop   = input.bool(false, "Use Trailing Stop",                                          group=gIchRisk)
trailOffset    = input.float(1.5,  "Trailing Stop % Offset",   minval=0.1, maxval=5,  step=0.1,  group=gIchRisk)

// Core Ichimoku calculations
tenkanSen   = (ta.highest(high, tenkanPeriod)      + ta.lowest(low, tenkanPeriod))      / 2
kijunSen    = (ta.highest(high, kijunPeriod)       + ta.lowest(low, kijunPeriod))       / 2
senkouSpanA = (tenkanSen + kijunSen) / 2
senkouSpanB = (ta.highest(high, senkouSpanBPeriod) + ta.lowest(low, senkouSpanBPeriod)) / 2
chikouSpan  = close

senkouA_disp = senkouSpanA[displacement]
senkouB_disp = senkouSpanB[displacement]
kumoGreen    = senkouSpanA > senkouSpanB
kumoRed      = senkouSpanA < senkouSpanB
cloudTop     = math.max(senkouA_disp, senkouB_disp)
cloudBottom  = math.min(senkouA_disp, senkouB_disp)

priceAboveCloud = close > cloudTop
priceBelowCloud = close < cloudBottom

bullishTKCross = ta.crossover(tenkanSen, kijunSen)
bearishTKCross = ta.crossunder(tenkanSen, kijunSen)
chikouBullish  = chikouSpan > close[displacement]
chikouBearish  = chikouSpan < close[displacement]

// Long entry filter chain
longCondition = bullishTKCross
if useCloudFilter
    longCondition := longCondition and kumoGreen
if strongSignalsOnly
    longCondition := longCondition and priceAboveCloud
if useChikouConfirmation
    longCondition := longCondition and chikouBullish

// Short entry filter chain
shortCondition = bearishTKCross
if useCloudFilter
    shortCondition := shortCondition and kumoRed
if strongSignalsOnly
    shortCondition := shortCondition and priceBelowCloud
if useChikouConfirmation
    shortCondition := shortCondition and chikouBearish

// Exit signals
longExit       = bearishTKCross
shortExit      = bullishTKCross
longExitCloud  = ta.crossunder(close, cloudBottom)
shortExitCloud = ta.crossover(close, cloudTop)

ichCalcSL(bool isLong, float entryPrice) =>
    float sl = 0.0
    if slType == "Kijun-Sen"
        sl := isLong ? kijunSen * (1 - slOffset/100) : kijunSen * (1 + slOffset/100)
    else if slType == "Recent Low/High" or slType == "Trailing Low"
        sl := isLong ? ta.lowest(low, recentLookback) * (1 - slOffset/100) : ta.highest(high, recentLookback) * (1 + slOffset/100)
    else
        sl := isLong ? entryPrice * (1 - slPercent/100) : entryPrice * (1 + slPercent/100)
    sl

ichCalcTP(bool isLong, float entryPrice, float stopLoss) =>
    float risk = math.abs(entryPrice - stopLoss)
    isLong ? entryPrice + risk * tpRatio : entryPrice - risk * tpRatio

// Simulated position state for SL/TP line drawing
var int   ichPos        = 0
var float ichLongEntry  = na
var float ichLongSL     = na
var float ichLongTP     = na
var float ichShortEntry = na
var float ichShortSL    = na
var float ichShortTP    = na

if useIchimoku
    // Enter
    if longCondition and ichPos == 0
        ichPos        := 1
        ichLongEntry  := close
        ichLongSL     := useSL ? ichCalcSL(true, close) : na
        ichLongTP     := useTP ? ichCalcTP(true, close, ichLongSL) : na
    else if shortCondition and ichPos == 0
        ichPos        := -1
        ichShortEntry := close
        ichShortSL    := useSL ? ichCalcSL(false, close) : na
        ichShortTP    := useTP ? ichCalcTP(false, close, ichShortSL) : na

    // Trailing for long
    if ichPos == 1 and slType == "Trailing Low"
        float newSL = low * (1 - slOffset/100)
        if newSL > ichLongSL
            ichLongSL := newSL
    if ichPos == -1 and slType == "Trailing Low"
        float newSL = high * (1 + slOffset/100)
        if newSL < ichShortSL
            ichShortSL := newSL

    // Generic trailing stop
    if trailingStop and ichPos == 1
        float newSL = close * (1 - trailOffset/100)
        if na(ichLongSL) or newSL > ichLongSL
            ichLongSL := newSL
    if trailingStop and ichPos == -1
        float newSL = close * (1 + trailOffset/100)
        if na(ichShortSL) or newSL < ichShortSL
            ichShortSL := newSL

    // Exits
    if ichPos == 1 and (low <= nz(ichLongSL, low - 1) or high >= nz(ichLongTP, high + 1) or longExit or longExitCloud)
        ichPos        := 0
        ichLongEntry  := na
        ichLongSL     := na
        ichLongTP     := na
    if ichPos == -1 and (high >= nz(ichShortSL, high + 1) or low <= nz(ichShortTP, low - 1) or shortExit or shortExitCloud)
        ichPos        := 0
        ichShortEntry := na
        ichShortSL    := na
        ichShortTP    := na

// Ichimoku plots (gated by master toggle)
plot(useIchimoku ? tenkanSen : na, "Tenkan-Sen", color=color.new(#2962FF, 0), linewidth=2)
plot(useIchimoku ? kijunSen  : na, "Kijun-Sen",  color=color.new(#FF6D00, 0), linewidth=2)

p1 = plot(useIchimoku ? senkouSpanA : na, "Senkou Span A", offset=displacement, color=color.new(#00E676, 0), linewidth=1)
p2 = plot(useIchimoku ? senkouSpanB : na, "Senkou Span B", offset=displacement, color=color.new(#FF1744, 0), linewidth=1)
cloudColor = kumoGreen ? color.new(#00E676, 85) : color.new(#FF1744, 85)
fill(p1, p2, color=useIchimoku ? cloudColor : na, title="Kumo Cloud")

plot(useIchimoku ? chikouSpan : na, "Chikou Span", offset=-displacement, color=color.new(#9C27B0, 0), linewidth=2)

// Layered signal classification
basicBull    = bullishTKCross and not priceAboveCloud and not chikouBullish
strongBull   = bullishTKCross and priceAboveCloud     and not chikouBullish
chikouBull   = bullishTKCross and chikouBullish       and not priceAboveCloud
ultimateBull = bullishTKCross and priceAboveCloud     and chikouBullish

basicBear    = bearishTKCross and not priceBelowCloud and not chikouBearish
strongBear   = bearishTKCross and priceBelowCloud     and not chikouBearish
chikouBear   = bearishTKCross and chikouBearish       and not priceBelowCloud
ultimateBear = bearishTKCross and priceBelowCloud     and chikouBearish

showBasicBull    = useIchimoku and (multiSignalDisplay ? basicBull    : (bullishTKCross and not strongSignalsOnly))
showStrongBull   = useIchimoku and (multiSignalDisplay ? strongBull   : (bullishTKCross and priceAboveCloud and strongSignalsOnly))
showChikouBull   = useIchimoku and  multiSignalDisplay and chikouBull
showUltimateBull = useIchimoku and  multiSignalDisplay and ultimateBull

showBasicBear    = useIchimoku and (multiSignalDisplay ? basicBear    : (bearishTKCross and not strongSignalsOnly))
showStrongBear   = useIchimoku and (multiSignalDisplay ? strongBear   : (bearishTKCross and priceBelowCloud and strongSignalsOnly))
showChikouBear   = useIchimoku and  multiSignalDisplay and chikouBear
showUltimateBear = useIchimoku and  multiSignalDisplay and ultimateBear

plotshape(showBasicBull,    title="Basic Bullish TK Cross", location=location.belowbar, color=color.new(#00E676, 0), style=shape.triangleup,   size=size.small,  text="BUY")
plotshape(showStrongBull,   title="Strong Bullish",         location=location.belowbar, color=color.new(#2962FF, 0), style=shape.triangleup,   size=size.small,  text="STRONG")
plotshape(showChikouBull,   title="Chikou Confirmation",    location=location.belowbar, color=color.new(#FFEB3B, 0), style=shape.triangleup,   size=size.small,  text="CHIKOU")
plotshape(showUltimateBull, title="Ultimate Bullish",       location=location.belowbar, color=color.new(#FFD700, 0), style=shape.diamond,      size=size.normal, text="ULT")

plotshape(showBasicBear,    title="Basic Bearish TK Cross",      location=location.abovebar, color=color.new(#FF1744, 0), style=shape.triangledown, size=size.small,  text="SELL")
plotshape(showStrongBear,   title="Strong Bearish",              location=location.abovebar, color=color.new(#FF6D00, 0), style=shape.triangledown, size=size.small,  text="STRONG")
plotshape(showChikouBear,   title="Chikou Confirmation Bearish", location=location.abovebar, color=color.new(#FFEB3B, 0), style=shape.triangledown, size=size.small,  text="CHIKOU")
plotshape(showUltimateBear, title="Ultimate Bearish",            location=location.abovebar, color=color.new(#8B0000, 0), style=shape.diamond,      size=size.normal, text="ULT")

plot(useIchimoku and ichPos ==  1 ? ichLongSL    : na, "Long Stop Loss",   color=color.new(color.red,    0),  style=plot.style_linebr, linewidth=2)
plot(useIchimoku and ichPos ==  1 ? ichLongTP    : na, "Long Take Profit", color=color.new(color.green,  0),  style=plot.style_linebr, linewidth=2)
plot(useIchimoku and ichPos ==  1 ? ichLongEntry : na, "Long Entry",       color=color.new(color.blue,   50), style=plot.style_linebr, linewidth=1)
plot(useIchimoku and ichPos == -1 ? ichShortSL    : na, "Short Stop Loss",   color=color.new(color.red,   0),  style=plot.style_linebr, linewidth=2)
plot(useIchimoku and ichPos == -1 ? ichShortTP    : na, "Short Take Profit", color=color.new(color.green, 0),  style=plot.style_linebr, linewidth=2)
plot(useIchimoku and ichPos == -1 ? ichShortEntry : na, "Short Entry",       color=color.new(color.orange,50), style=plot.style_linebr, linewidth=1)

bgcolor(useIchimoku and priceAboveCloud and kumoGreen ? color.new(color.green, 95) : na, title="Bullish Zone")
bgcolor(useIchimoku and priceBelowCloud and kumoRed   ? color.new(color.red,   95) : na, title="Bearish Zone")

alertcondition(useIchimoku and longCondition,                      title="ICH Long",         message="ICHIMOKU LONG | Price: {{close}}")
alertcondition(useIchimoku and shortCondition,                     title="ICH Short",        message="ICHIMOKU SHORT | Price: {{close}}")
alertcondition(useIchimoku and longExit,                           title="ICH Long Exit",    message="ICHIMOKU: Close LONG | Price: {{close}}")
alertcondition(useIchimoku and shortExit,                          title="ICH Short Exit",   message="ICHIMOKU: Close SHORT | Price: {{close}}")
alertcondition(useIchimoku and bullishTKCross and priceAboveCloud, title="ICH Strong Long",  message="STRONG BULL | Price: {{close}}")
alertcondition(useIchimoku and bearishTKCross and priceBelowCloud, title="ICH Strong Short", message="STRONG BEAR | Price: {{close}}")


// =====================================================================
// MODULE 4: SILVER CONTEXT
// Fresh implementation: trend EMA + DXY/US10Y macro stress + flush detect
// =====================================================================
var string gSilver      = "Silver Context"
var string gSilverFlush = "Silver · Flush Protection"

silverStartDate     = input.time(timestamp("2021-01-01 00:00 +0000"), "Start date", group=gSilver)
useDateFilter       = input.bool(true,  "Use start date filter",                    group=gSilver)
silverSlowLen       = input.int(150,    "Silver EMA slow",          minval=1,       group=gSilver)
silverRecoveryLen   = input.int(75,     "Silver recovery EMA",      minval=1,       group=gSilver)
useSilverTrendExit  = input.bool(true,  "Use silver trend exit",                    group=gSilver)
silverExitBufferPct = input.float(0.0,  "Silver exit buffer % under EMA", minval=0.0, step=0.1, group=gSilver)

dxySymbol           = input.symbol("TVC:DXY",   "DXY symbol",                       group=gSilver)
useDxyExit          = input.bool(false, "Use DXY exit",                             group=gSilver)
dxyLen              = input.int(50,     "DXY EMA length",            minval=1,      group=gSilver)
dxyBreakoutLookback = input.int(20,     "DXY breakout lookback",     minval=2,      group=gSilver)
dxyMaxAboveEmaPct   = input.float(1.0,  "DXY % above EMA for exit",  minval=0.0, step=0.1, group=gSilver)

us10ySymbol           = input.symbol("TVC:US10Y", "US10Y symbol",                   group=gSilver)
useUs10yExit          = input.bool(true,  "Use US10Y exit",                         group=gSilver)
us10yLen              = input.int(50,     "US10Y EMA length",       minval=1,       group=gSilver)
us10yBreakoutLookback = input.int(20,     "US10Y breakout lookback", minval=2,      group=gSilver)
us10yMaxAboveEmaPct   = input.float(1.35, "US10Y % above EMA for exit", minval=0.0, step=0.05, group=gSilver)

macroExitBars = input.int(3, "Bars macro stress before exit", minval=1, group=gSilver)
reEntryBars   = input.int(1, "Bars calm before re-entry",     minval=1, group=gSilver)

useFlushExit      = input.bool(true,  "Use silver flush exit",            group=gSilverFlush)
oneDayFlushPct    = input.float(4.5,  "One day flush %",   minval=0.1, step=0.1, group=gSilverFlush)
twoDayFlushPct    = input.float(8.0,  "Two day flush %",   minval=0.1, step=0.1, group=gSilverFlush)
silverAtrLen      = input.int(14,     "ATR length",        minval=1,             group=gSilverFlush)
atrShockMult      = input.float(1.8,  "ATR shock multiplier", minval=0.1, step=0.1, group=gSilverFlush)
flushCooldownBars = input.int(3,      "Bars after flush before normal entry", minval=1, group=gSilverFlush)
volCalmBars       = input.int(2,      "Bars volatility calm before re-entry", minval=1, group=gSilverFlush)

silverShowTable = input.bool(true, "Show status table", group=gSilver)
silverTablePos  = input.string("Top Left", "Status table position", options=["Top Left", "Top Right", "Bottom Left", "Bottom Right"], group=gSilver)

inTradeWindow     = not useDateFilter or time >= silverStartDate

silverEmaSlow     = ta.ema(close, silverSlowLen)
silverRecoveryEma = ta.ema(close, silverRecoveryLen)
silverBelowSlow   = close < silverEmaSlow * (1.0 - silverExitBufferPct / 100.0)
silverTrendExit   = useSilverTrendExit and silverBelowSlow

dxyClose    = request.security(dxySymbol, timeframe.period, close,                           barmerge.gaps_off, barmerge.lookahead_off)
dxyEma      = request.security(dxySymbol, timeframe.period, ta.ema(close, dxyLen),           barmerge.gaps_off, barmerge.lookahead_off)
dxyHighPrev = request.security(dxySymbol, timeframe.period, ta.highest(high[1], dxyBreakoutLookback), barmerge.gaps_off, barmerge.lookahead_off)

us10yClose    = request.security(us10ySymbol, timeframe.period, close,                              barmerge.gaps_off, barmerge.lookahead_off)
us10yEma      = request.security(us10ySymbol, timeframe.period, ta.ema(close, us10yLen),            barmerge.gaps_off, barmerge.lookahead_off)
us10yHighPrev = request.security(us10ySymbol, timeframe.period, ta.highest(high[1], us10yBreakoutLookback), barmerge.gaps_off, barmerge.lookahead_off)

dxyAbovePct   = dxyEma   != 0 ? (dxyClose   - dxyEma)   / dxyEma   * 100.0 : 0.0
us10yAbovePct = us10yEma != 0 ? (us10yClose - us10yEma) / us10yEma * 100.0 : 0.0

dxyStress   = useDxyExit   and dxyClose   > dxyEma   and dxyAbovePct   > dxyMaxAboveEmaPct   and dxyClose   > dxyHighPrev
us10yStress = useUs10yExit and us10yClose > us10yEma and us10yAbovePct > us10yMaxAboveEmaPct and us10yClose > us10yHighPrev

macroStressNow     = dxyStress or us10yStress
macroStressPersist = f_persist(macroStressNow, macroExitBars)

dxyCalm      = not useDxyExit   or dxyClose   <= dxyEma   or dxyAbovePct   <= dxyMaxAboveEmaPct
us10yCalm    = not useUs10yExit or us10yClose <= us10yEma or us10yAbovePct <= us10yMaxAboveEmaPct
macroCalmNow = dxyCalm and us10yCalm
macroCalmPersist = f_persist(macroCalmNow, reEntryBars)

oneDayMovePct = close[1] != 0 ? (close / close[1] - 1.0) * 100.0 : 0.0
twoDayMovePct = close[2] != 0 ? (close / close[2] - 1.0) * 100.0 : 0.0

silverAtr    = ta.atr(silverAtrLen)
silverAtrPct = close != 0 ? silverAtr / close * 100.0 : 0.0
rangePct     = close != 0 ? (high - low) / close * 100.0 : 0.0

oneDayFlush = oneDayMovePct <= -oneDayFlushPct
twoDayFlush = twoDayMovePct <= -twoDayFlushPct
atrShock    = rangePct > silverAtrPct * atrShockMult and close < open
flushShockNow = useFlushExit and (oneDayFlush or twoDayFlush or atrShock)

barsSinceFlush     = ta.barssince(flushShockNow)
flushRecently      = useFlushExit and not na(barsSinceFlush) and barsSinceFlush <= flushCooldownBars
volCalmNow         = not useFlushExit or rangePct <= silverAtrPct * atrShockMult
volCalmPersist     = f_persist(volCalmNow, volCalmBars)
flushRecoveryReady = not useFlushExit or not flushRecently or (close > silverRecoveryEma and volCalmPersist)

var bool silverInLong = false
silverExitCondition  = inTradeWindow and (silverTrendExit or macroStressPersist or flushShockNow)
silverEntryCondition = inTradeWindow and not silverInLong and not silverTrendExit and macroCalmPersist and flushRecoveryReady

if useSilver
    if silverInLong and silverExitCondition
        silverInLong := false
    else if silverEntryCondition
        silverInLong := true

plot(useSilver ? silverEmaSlow     : na, "Silver EMA slow",     color=color.blue,   linewidth=2)
plot(useSilver ? silverRecoveryEma : na, "Silver recovery EMA", color=color.orange, linewidth=1)

plotshape(useSilver and silverEntryCondition,                 title="Silver Long entry",  style=shape.triangleup,   location=location.belowbar, color=color.lime,   size=size.small, text="Long")
plotshape(useSilver and silverExitCondition  and silverInLong, title="Silver Exit",        style=shape.triangledown, location=location.abovebar, color=color.red,    size=size.small, text="Exit")
plotshape(useSilver and flushShockNow,                        title="Silver flush shock", style=shape.diamond,      location=location.abovebar, color=color.yellow, size=size.small, text="Flush")

bgcolor(useSilver and macroStressNow ? color.new(color.red,    88) : na, title="Macro stress background")
bgcolor(useSilver and flushRecently  ? color.new(color.orange, 88) : na, title="Flush cooldown background")

alertcondition(useSilver and silverEntryCondition,                 title="Silver Long Entry", message="Silver: Entry | Price: {{close}}")
alertcondition(useSilver and silverExitCondition and silverInLong, title="Silver Exit",       message="Silver: Exit | Price: {{close}}")
alertcondition(useSilver and flushShockNow,                        title="Silver Flush",      message="Silver: Flush shock | Price: {{close}}")

var float bhStartPrice = na
var int   bhStartTime  = na
if useSilver and inTradeWindow and na(bhStartPrice)
    bhStartPrice := close
    bhStartTime  := time
buyHoldReturnPct = not na(bhStartPrice) ? (close / bhStartPrice - 1.0) * 100.0 : na

silverTablePosition = silverTablePos == "Top Left" ? position.top_left : silverTablePos == "Top Right" ? position.top_right : silverTablePos == "Bottom Left" ? position.bottom_left : position.bottom_right
var table silverStatusTable = table.new(silverTablePosition, 2, 12, border_width=1)

if useSilver and silverShowTable and barstate.islast
    table.cell(silverStatusTable, 0, 0,  "Silver Status",  text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 0,  silverInLong ? "Long" : "Flat", text_color=color.white, bgcolor=silverInLong ? color.green : color.red)
    table.cell(silverStatusTable, 0, 1,  "Buy & Hold",     text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 1,  not na(buyHoldReturnPct) ? str.tostring(buyHoldReturnPct, "#.##") + "%" : "n/a", text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 0, 2,  "BH start",       text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 2,  not na(bhStartTime) ? str.format("{0,date,yyyy-MM-dd}", bhStartTime) : "n/a", text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 0, 3,  "Silver trend",   text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 3,  silverTrendExit ? "Weak" : "OK", text_color=color.white, bgcolor=silverTrendExit ? color.red : color.green)
    table.cell(silverStatusTable, 0, 4,  "Macro stress",   text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 4,  macroStressNow ? "Yes" : "No", text_color=color.white, bgcolor=macroStressNow ? color.red : color.green)
    table.cell(silverStatusTable, 0, 5,  "DXY stress",     text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 5,  dxyStress ? "Yes" : "No", text_color=color.white, bgcolor=dxyStress ? color.red : color.green)
    table.cell(silverStatusTable, 0, 6,  "US10Y stress",   text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 6,  us10yStress ? "Yes" : "No", text_color=color.white, bgcolor=us10yStress ? color.red : color.green)
    table.cell(silverStatusTable, 0, 7,  "Flush shock",    text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 7,  flushShockNow ? "Yes" : "No", text_color=color.white, bgcolor=flushShockNow ? color.orange : color.green)
    table.cell(silverStatusTable, 0, 8,  "Flush cooldown", text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 8,  flushRecently ? "Active" : "No", text_color=color.white, bgcolor=flushRecently ? color.orange : color.green)
    table.cell(silverStatusTable, 0, 9,  "Re-entry ready", text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 9,  flushRecoveryReady and macroCalmPersist ? "Yes" : "No", text_color=color.white, bgcolor=flushRecoveryReady and macroCalmPersist ? color.green : color.red)
    table.cell(silverStatusTable, 0, 10, "US10Y above EMA", text_color=color.white, bgcolor=color.black)
    table.cell(silverStatusTable, 1, 10, str.tostring(us10yAbovePct, "#.##") + "%", text_color=color.white, bgcolor=color.black)
else if not useSilver
    table.clear(silverStatusTable, 0, 0, 1, 10)


// =====================================================================
// MODULE 5: MULTI-TF FAIR VALUE GAP
// Fresh implementation of public ICT 3-candle gap pattern.
// Bullish FVG: low[0] > high[2]   (gap left between bar 2's high and bar 0's low)
// Bearish FVG: high[0] < low[2]
// =====================================================================
var string gFvg = "FVG (Multi-TF)"

fvgTimeframe       = input.timeframe("",   "FVG Timeframe (empty = chart TF)", group=gFvg)
fvgMaxBoxes        = input.int(15,         "Max active FVG boxes",       minval=1, maxval=50, group=gFvg)
fvgExtendBars      = input.int(50,         "Extend right (bars)",        minval=1,            group=gFvg)
fvgBullColor       = input.color(color.new(color.green, 75), "Bullish FVG fill",   group=gFvg)
fvgBearColor       = input.color(color.new(color.red,   75), "Bearish FVG fill",   group=gFvg)
fvgBullBorder      = input.color(color.new(color.green, 0),  "Bullish FVG border", group=gFvg)
fvgBearBorder      = input.color(color.new(color.red,   0),  "Bearish FVG border", group=gFvg)
fvgShowSignals     = input.bool(true,      "Show buy/sell signal shapes", group=gFvg)
fvgRemoveMitigated = input.bool(true,      "Remove mitigated FVGs",       group=gFvg)

fvgTf = fvgTimeframe == "" ? timeframe.period : fvgTimeframe
[fvgH2, fvgL2, fvgH0, fvgL0] = request.security(syminfo.tickerid, fvgTf, [high[2], low[2], high, low], lookahead=barmerge.lookahead_off)

bullFvgFormed = useFvg and not na(fvgH2) and not na(fvgL0) and fvgL0 > fvgH2
bearFvgFormed = useFvg and not na(fvgL2) and not na(fvgH0) and fvgH0 < fvgL2

var array<box>   bullFvgBoxes   = array.new<box>()
var array<float> bullFvgBottoms = array.new<float>()
var array<box>   bearFvgBoxes   = array.new<box>()
var array<float> bearFvgTops    = array.new<float>()

if bullFvgFormed
    box b = box.new(bar_index - 1, fvgL0, bar_index + fvgExtendBars, fvgH2, border_color=fvgBullBorder, bgcolor=fvgBullColor)
    array.push(bullFvgBoxes, b)
    array.push(bullFvgBottoms, fvgH2)
    if array.size(bullFvgBoxes) > fvgMaxBoxes
        box.delete(array.shift(bullFvgBoxes))
        array.shift(bullFvgBottoms)

if bearFvgFormed
    box b = box.new(bar_index - 1, fvgH0, bar_index + fvgExtendBars, fvgL2, border_color=fvgBearBorder, bgcolor=fvgBearColor)
    array.push(bearFvgBoxes, b)
    array.push(bearFvgTops, fvgL2)
    if array.size(bearFvgBoxes) > fvgMaxBoxes
        box.delete(array.shift(bearFvgBoxes))
        array.shift(bearFvgTops)

if useFvg and fvgRemoveMitigated
    if array.size(bullFvgBoxes) > 0
        for i = array.size(bullFvgBoxes) - 1 to 0
            if i < array.size(bullFvgBoxes)
                if low < array.get(bullFvgBottoms, i)
                    box.delete(array.get(bullFvgBoxes, i))
                    array.remove(bullFvgBoxes, i)
                    array.remove(bullFvgBottoms, i)
    if array.size(bearFvgBoxes) > 0
        for i = array.size(bearFvgBoxes) - 1 to 0
            if i < array.size(bearFvgBoxes)
                if high > array.get(bearFvgTops, i)
                    box.delete(array.get(bearFvgBoxes, i))
                    array.remove(bearFvgBoxes, i)
                    array.remove(bearFvgTops, i)

plotshape(useFvg and fvgShowSignals and bullFvgFormed, title="FVG Buy",  location=location.belowbar, color=color.new(color.green, 0), style=shape.labelup,   size=size.tiny, text="FVG")
plotshape(useFvg and fvgShowSignals and bearFvgFormed, title="FVG Sell", location=location.abovebar, color=color.new(color.red,   0), style=shape.labeldown, size=size.tiny, text="FVG")

alertcondition(useFvg and bullFvgFormed, title="FVG Bull", message="Bullish FVG formed | Price: {{close}}")
alertcondition(useFvg and bearFvgFormed, title="FVG Bear", message="Bearish FVG formed | Price: {{close}}")


// =====================================================================
// MODULE 2: LIQUIDITY DELTA PROFILER
// Adapted from "Liquidity Delta Profiler [LuxAlgo]" © LuxAlgo
// Licensed CC BY-NC-SA 4.0 — https://creativecommons.org/licenses/by-nc-sa/4.0/
// This combined work's Liquidity Delta module portion is also CC BY-NC-SA 4.0.
// Toggle: useLiquidity
// =====================================================================
var string gLq      = "Liquidity Delta"
var string gLqStyle = "Liquidity Delta · Style"
var string gLqDash  = "Liquidity Delta · Dashboard"

color LQ_DATA       = #DBDBDB
color LQ_HEADERS    = #808080
color LQ_BACKGROUND = #161616
color LQ_BORDERS    = #2E2E2E

string LQ_TOP_RIGHT    = 'Top Right'
string LQ_BOTTOM_RIGHT = 'Bottom Right'
string LQ_BOTTOM_LEFT  = 'Bottom Left'
string LQ_TINY    = 'Tiny'
string LQ_SMALL   = 'Small'
string LQ_NORMAL  = 'Normal'
string LQ_LARGE   = 'Large'
string LQ_HUGE    = 'Huge'

lqLength         = input.int(15,   "Pivot Length",        minval=2,            group=gLq, tooltip="Lookback and lookforward length for detecting major swing highs/lows.")
lqMaxZones       = input.int(10,   "Max Zones per Type",  minval=1, maxval=40, group=gLq, tooltip="Maximum number of active/historical buy and sell zones to keep on the chart.")
lqShowSwept      = input.bool(true, "Show Swept Zones",   group=gLq, tooltip="Keep zones visible after price sweeps them.")
lqFilterOverlaps = input.bool(true, "Filter Overlapping Zones", group=gLq, tooltip="Prevents creating new zones that overlap with existing active zones.")

lqShowDecay      = input.bool(true, "Show Zone Decay",       group=gLq, tooltip="Displays remaining 'health' of active zones based on volume traded inside them.")
lqZoneCapacity   = input.float(5.0, "Zone Volume Capacity", minval=1.0, group=gLq, tooltip="Multiplier for average volume to determine zone capacity.")

lqEnableReversals = input.bool(true, "Enable Reversal Detection", group=gLq, tooltip="Detects unusual volume delta patterns during liquidity sweeps. Plots ABS/EXH/DIV/REJ labels.")

lqDashboard         = input.bool(true,         "Show Dashboard", group=gLqDash)
lqDashboardPosition = input.string(LQ_TOP_RIGHT, "Position",     options=[LQ_TOP_RIGHT, LQ_BOTTOM_RIGHT, LQ_BOTTOM_LEFT], group=gLqDash)
lqDashboardSize     = input.string(LQ_TINY,    "Size",           options=[LQ_TINY, LQ_SMALL, LQ_NORMAL, LQ_LARGE, LQ_HUGE], group=gLqDash)
lqDashboardWindow   = input.int(10,            "Eval Window (Bars)", minval=1, group=gLqDash)
lqDashboardHold     = input.int(3,             "Hold Time (Bars)",   minval=1, group=gLqDash)
lqDashboardHilite   = input.bool(false,        "Highlight Eval Bars", group=gLqDash)

lqBslColor       = input.color(color.new(#f23645, 0), "BSL Outline Color", group=gLqStyle)
lqSslColor       = input.color(color.new(#089981, 0), "SSL Outline Color", group=gLqStyle)
lqBuyDeltaColor  = input.color(color.new(#089981, 0), "Buy Delta Fill",    group=gLqStyle)
lqSellDeltaColor = input.color(color.new(#f23645, 0), "Sell Delta Fill",   group=gLqStyle)

type LqZone
    float top
    float bottom
    int   left
    int   right
    bool  swept
    bool  signaled
    array<box>   quads
    array<float> deltas
    box   outline
    float volumeTraded
    float capacity
    bool  wasHit
    label decayLabel

type LqTrade
    string type
    int    dir
    float  entry
    int    entryBar
    bool   active
    bool   won
    int    consecBars

var array<LqZone>  bslZones      = array.new<LqZone>()
var array<LqZone>  sslZones      = array.new<LqZone>()
var array<LqTrade> activeTrades  = array.new<LqTrade>()

var int absTotal = 0
var int absWins  = 0
var int exhTotal = 0
var int exhWins  = 0
var int divTotal = 0
var int divWins  = 0
var int rejTotal = 0
var int rejWins  = 0

var string parsedDashboardPosition = switch lqDashboardPosition
    LQ_TOP_RIGHT    => position.top_right
    LQ_BOTTOM_RIGHT => position.bottom_right
    LQ_BOTTOM_LEFT  => position.bottom_left
    => position.top_right

var string parsedDashboardSize = switch lqDashboardSize
    LQ_TINY   => size.tiny
    LQ_SMALL  => size.small
    LQ_NORMAL => size.normal
    LQ_LARGE  => size.large
    LQ_HUGE   => size.huge
    => size.normal

var table lqTable = table.new(parsedDashboardPosition, 4, 11, bgcolor=lqDashboard and useLiquidity ? LQ_BACKGROUND : na, border_width=0, frame_color=lqDashboard and useLiquidity ? LQ_BORDERS : na, frame_width=1, force_overlay=true)

lqCell(table t, int col, int r, string data, color txtColor=color.white, string align=text.align_right, color background=na, float h=0) =>
    t.cell(col, r, data, text_color=txtColor, text_size=parsedDashboardSize, text_halign=align, bgcolor=background, height=h)

lqDivider(table t, int r, int lastColumn) =>
    string rowDivider = '----------------'
    t.merge_cells(0, r, lastColumn, r)
    lqCell(t, 0, r, rowDivider, txtColor=LQ_BORDERS, align=text.align_center, h=0.5)

method lqEvaluateReversals(LqZone z, bool isBsl, float barH, float barL, float barC, float barO, float barDelta, float barVol) =>
    if lqEnableReversals and not z.signaled
        float totalD    = 0.0
        float absTotalD = 0.0
        for d in z.deltas
            totalD    += d
            absTotalD += math.abs(d)

        if absTotalD > 0
            int   outerIdx = isBsl ? 3 : 0
            float outerD   = z.deltas.get(outerIdx)

            bool isSweeping     = isBsl ? barH > z.top : barL < z.bottom
            bool closesInside   = isBsl ? (barC <= z.top and barC >= z.bottom) : (barC >= z.bottom and barC <= z.top)
            float midPoint      = (z.top + z.bottom) / 2
            bool closesRejecting = isBsl ? barC < midPoint : barC > midPoint

            string signalType = ""
            string tooltipTxt = ""
            float  significance = 0.0
            color  sigColor   = isBsl ? color.red : color.green

            // Absorption at extreme
            if isSweeping and ((isBsl and outerD < 0) or (not isBsl and outerD > 0))
                float ratio = math.abs(outerD) / (absTotalD + 0.0001)
                if ratio > 0.2
                    signalType   := "ABS"
                    tooltipTxt   := "Absorption at Extreme\n" + (isBsl ? "Sellers" : "Buyers") + " aggressively absorbed the sweep.\nOuter Quadrant Delta: " + str.tostring(outerD, format.volume)
                    significance := ratio * 2

            // Exhaustion (dry sweep)
            if signalType == "" and isSweeping
                float ratio = math.abs(outerD) / (absTotalD + 0.0001)
                if ratio < 0.1
                    signalType   := "EXH"
                    tooltipTxt   := "Exhaustion (Dry Sweep)\nMinimal volume at the extreme edge.\nOuter Quadrant Delta: " + str.tostring(outerD, format.volume)
                    significance := 1.0 - (ratio * 5)

            // Delta divergence (FOMO trap)
            if signalType == "" and closesInside
                float ratio = math.abs(outerD) / (absTotalD + 0.0001)
                if ratio > 0.6 and ((isBsl and outerD > 0) or (not isBsl and outerD < 0))
                    signalType   := "DIV"
                    tooltipTxt   := "Delta Divergence (FOMO)\nHigh volume trapped at the extreme, but price failed to breakout.\nOuter Quadrant Delta: " + str.tostring(outerD, format.volume)
                    significance := ratio

            // Snapback rejection
            if signalType == "" and isSweeping and closesRejecting
                float barRatio = math.abs(barDelta) / (barVol + 0.0001)
                if ((isBsl and barDelta < 0) or (not isBsl and barDelta > 0)) and barRatio > 0.2
                    signalType   := "REJ"
                    tooltipTxt   := "Snapback Rejection\nSweep followed by immediate strong rejection.\nBar Delta: " + str.tostring(barDelta, format.volume)
                    significance := barRatio * 2

            if signalType != ""
                z.signaled := true
                alert("Reversal Signal (" + signalType + ") detected at " + str.tostring(barC), alert.freq_once_per_bar)

                significance := math.min(math.max(significance, 0.0), 1.0)
                string sSize = size.tiny
                int    trans = 50

                if significance > 0.7
                    sSize := size.normal
                    trans := 10
                else if significance > 0.4
                    sSize := size.small
                    trans := 30

                color  finalColor  = color.new(sigColor, trans)
                float  yLoc        = isBsl ? barH : barL
                string labelStyle  = isBsl ? label.style_label_down : label.style_label_up

                label.new(bar_index, yLoc, text=signalType, color=finalColor, style=labelStyle, textcolor=color.white, size=sSize, tooltip=tooltipTxt)

                activeTrades.push(LqTrade.new(signalType, isBsl ? -1 : 1, barC, bar_index, true, false, 0))

method lqUpdateVisuals(LqZone z, bool isBsl, bool showS, color buyC, color sellC, color bslC, color sslC) =>
    float maxD = 0.0
    for d in z.deltas
        maxD := math.max(maxD, math.abs(d))

    for i = 0 to 3
        float d   = z.deltas.get(i)
        color c   = na
        string txt = ""
        color tColor = na
        if maxD > 0 and math.abs(d) > 0.001
            color baseC = d > 0 ? buyC : sellC
            int trans = z.swept ? 90 : 100 - int((math.abs(d) / maxD) * 60)
            c := color.rgb(color.r(baseC), color.g(baseC), color.b(baseC), trans)
            txt := (d > 0 ? "+" : d < 0 ? "-" : "") + str.tostring(math.abs(d), format.volume)
            tColor := color.new(baseC, z.swept ? 50 : 0)
        else
            color baseC = isBsl ? bslC : sslC
            int defaultTrans = 60 + (isBsl ? (3 - i) : i) * 10
            c := color.rgb(color.r(baseC), color.g(baseC), color.b(baseC), z.swept ? 90 : defaultTrans)
            txt := "0"
            tColor := color.new(baseC, z.swept ? 80 : 50)

        box q = z.quads.get(i)
        q.set_bgcolor(not showS and z.swept ? na : c)
        q.set_text(not showS and z.swept ? "" : txt)
        q.set_text_color(not showS and z.swept ? na : tColor)

        if z.swept
            q.set_border_color(not showS ? na : color.new(isBsl ? bslC : sslC, 80))
            q.set_border_style(line.style_dashed)
        else
            q.set_border_color(color.new(isBsl ? bslC : sslC, 60))
            q.set_border_style(line.style_solid)

    if z.swept
        if showS
            z.outline.set_border_style(line.style_dashed)
            z.outline.set_border_color(color.new(isBsl ? bslC : sslC, 80))
        else
            z.outline.set_border_color(na)

lqBarOverlap(float barH, float barL, float qTop, float qBot) =>
    float overlapTop = math.min(barH, qTop)
    float overlapBot = math.max(barL, qBot)
    overlapTop > overlapBot ? (overlapTop - overlapBot) : 0.0

float lqAtr = atr14
float lqPh  = ta.pivothigh(high, lqLength, lqLength)
float lqPl  = ta.pivotlow(low,  lqLength, lqLength)
float lqAvgVol = nz(ta.sma(volume, lqLength))
if lqAvgVol == 0
    lqAvgVol := 1
float lqZoneCap = lqAvgVol * lqZoneCapacity

if useLiquidity and not na(lqPh) and bar_index >= lqLength
    int   pivotIdx = bar_index - lqLength
    float pHigh    = high[lqLength]
    float pBot     = math.max(close[lqLength], open[lqLength])
    if pHigh - pBot < lqAtr[lqLength] * 0.1
        pBot := pHigh - lqAtr[lqLength] * 0.1

    bool skip = false
    if lqFilterOverlaps and bslZones.size() > 0
        for i = bslZones.size() - 1 to 0
            if i < bslZones.size()
                LqZone ex = bslZones.get(i)
                if not ex.swept
                    bool overlaps = math.max(pBot, ex.bottom) <= math.min(pHigh, ex.top)
                    if overlaps
                        if pHigh > ex.top
                            for b in ex.quads
                                b.delete()
                            ex.outline.delete()
                            ex.decayLabel.delete()
                            bslZones.remove(i)
                        else
                            skip := true
                            break

    if not skip
        array<box>   quads  = array.new<box>(4)
        array<float> deltas = array.new<float>(4, 0.0)
        float step = (pHigh - pBot) / 4
        for i = 0 to 3
            float qBot = pBot + i * step
            float qTop = pBot + (i + 1) * step
            color baseC = lqBslColor
            int trans = 60 + (3 - i) * 10
            color c = color.rgb(color.r(baseC), color.g(baseC), color.b(baseC), trans)
            float gap = step * 0.05
            float bTop = qTop - gap
            float bBot = qBot + gap
            if i == 0
                bBot := qBot
            if i == 3
                bTop := qTop
            quads.set(i, box.new(pivotIdx, bTop, pivotIdx, bBot, border_color=color.new(baseC, 60), bgcolor=c, text="0", text_color=color.new(baseC, 50), text_halign=text.align_right, text_size=size.auto))

        box outline = box.new(pivotIdx, pHigh, pivotIdx, pBot, border_color=color.new(lqBslColor, 80), bgcolor=na)
        label dLabel = label.new(bar_index, pBot + (pHigh - pBot)/2, text="100%", style=label.style_label_left, color=color.new(lqBslColor, 80), textcolor=color.white, size=size.small)
        if not lqShowDecay
            dLabel.set_x(na)

        LqZone z = LqZone.new(pHigh, pBot, pivotIdx, pivotIdx, false, false, quads, deltas, outline, 0.0, lqZoneCap, false, dLabel)
        bslZones.unshift(z)
        if bslZones.size() > lqMaxZones
            LqZone removed = bslZones.pop()
            for b in removed.quads
                b.delete()
            removed.outline.delete()
            removed.decayLabel.delete()

if useLiquidity and not na(lqPl) and bar_index >= lqLength
    int   pivotIdx = bar_index - lqLength
    float pLow     = low[lqLength]
    float pTop     = math.min(close[lqLength], open[lqLength])
    if pTop - pLow < lqAtr[lqLength] * 0.1
        pTop := pLow + lqAtr[lqLength] * 0.1

    bool skip = false
    if lqFilterOverlaps and sslZones.size() > 0
        for i = sslZones.size() - 1 to 0
            if i < sslZones.size()
                LqZone ex = sslZones.get(i)
                if not ex.swept
                    bool overlaps = math.max(pLow, ex.bottom) <= math.min(pTop, ex.top)
                    if overlaps
                        if pLow < ex.bottom
                            for b in ex.quads
                                b.delete()
                            ex.outline.delete()
                            ex.decayLabel.delete()
                            sslZones.remove(i)
                        else
                            skip := true
                            break

    if not skip
        array<box>   quads  = array.new<box>(4)
        array<float> deltas = array.new<float>(4, 0.0)
        float step = (pTop - pLow) / 4
        for i = 0 to 3
            float qBot = pLow + i * step
            float qTop = pLow + (i + 1) * step
            color baseC = lqSslColor
            int trans = 60 + i * 10
            color c = color.rgb(color.r(baseC), color.g(baseC), color.b(baseC), trans)
            float gap = step * 0.05
            float bTop = qTop - gap
            float bBot = qBot + gap
            if i == 0
                bBot := qBot
            if i == 3
                bTop := qTop
            quads.set(i, box.new(pivotIdx, bTop, pivotIdx, bBot, border_color=color.new(baseC, 60), bgcolor=c, text="0", text_color=color.new(baseC, 50), text_halign=text.align_right, text_size=size.auto))

        box outline = box.new(pivotIdx, pTop, pivotIdx, pLow, border_color=color.new(lqSslColor, 80), bgcolor=na)
        label dLabel = label.new(bar_index, pLow + (pTop - pLow)/2, text="100%", style=label.style_label_left, color=color.new(lqSslColor, 80), textcolor=color.white, size=size.small)
        if not lqShowDecay
            dLabel.set_x(na)

        LqZone z = LqZone.new(pTop, pLow, pivotIdx, pivotIdx, false, false, quads, deltas, outline, 0.0, lqZoneCap, false, dLabel)
        sslZones.unshift(z)
        if sslZones.size() > lqMaxZones
            LqZone removed = sslZones.pop()
            for b in removed.quads
                b.delete()
            removed.outline.delete()
            removed.decayLabel.delete()

float lqVol      = nz(volume)
float lqTotalR   = high - low
float lqBarDelta = lqTotalR == 0 ? 0 : lqVol * (close - open) / lqTotalR

if useLiquidity and bslZones.size() > 0
    for i = bslZones.size() - 1 to 0
        if i < bslZones.size()
            LqZone z = bslZones.get(i)
            if not z.swept
                z.right := bar_index
                z.outline.set_right(bar_index)
                for b in z.quads
                    b.set_right(bar_index)

                bool hit = false
                float step = (z.top - z.bottom) / 4
                for j = 0 to 3
                    float qBot = z.bottom + j * step
                    float qTop = z.bottom + (j + 1) * step
                    float overlap = lqBarOverlap(high, low, qTop, qBot)
                    if overlap > 0
                        hit := true
                        float overlapRatio = lqTotalR == 0 ? 0 : overlap / lqTotalR
                        float qDelta = lqBarDelta * overlapRatio
                        z.deltas.set(j, z.deltas.get(j) + qDelta)
                        z.volumeTraded += lqVol * overlapRatio

                if hit and not z.wasHit
                    alert("Price testing Resistance BSL Zone at " + str.tostring(z.top), alert.freq_once_per_bar)

                if high > z.top
                    z.swept := true
                    alert("Resistance BSL Zone Swept at " + str.tostring(z.top), alert.freq_once_per_bar)

                if not z.swept
                    if lqShowDecay
                        int health = int(math.max(0, 100 - (z.volumeTraded / z.capacity * 100)))
                        z.decayLabel.set_x(bar_index + 1)
                        z.decayLabel.set_text(str.tostring(health) + "%")
                    else
                        z.decayLabel.set_x(na)
                else
                    z.decayLabel.delete()

                z.wasHit := hit

                if hit or z.swept
                    z.lqEvaluateReversals(true, high, low, close, open, lqBarDelta, lqVol)
                    z.lqUpdateVisuals(true, lqShowSwept, lqBuyDeltaColor, lqSellDeltaColor, lqBslColor, lqSslColor)

if useLiquidity and sslZones.size() > 0
    for i = sslZones.size() - 1 to 0
        if i < sslZones.size()
            LqZone z = sslZones.get(i)
            if not z.swept
                z.right := bar_index
                z.outline.set_right(bar_index)
                for b in z.quads
                    b.set_right(bar_index)

                bool hit = false
                float step = (z.top - z.bottom) / 4
                for j = 0 to 3
                    float qBot = z.bottom + j * step
                    float qTop = z.bottom + (j + 1) * step
                    float overlap = lqBarOverlap(high, low, qTop, qBot)
                    if overlap > 0
                        hit := true
                        float overlapRatio = lqTotalR == 0 ? 0 : overlap / lqTotalR
                        float qDelta = lqBarDelta * overlapRatio
                        z.deltas.set(j, z.deltas.get(j) + qDelta)
                        z.volumeTraded += lqVol * overlapRatio

                if hit and not z.wasHit
                    alert("Price testing Support SSL Zone at " + str.tostring(z.bottom), alert.freq_once_per_bar)

                if low < z.bottom
                    z.swept := true
                    alert("Support SSL Zone Swept at " + str.tostring(z.bottom), alert.freq_once_per_bar)

                if not z.swept
                    if lqShowDecay
                        int health = int(math.max(0, 100 - (z.volumeTraded / z.capacity * 100)))
                        z.decayLabel.set_x(bar_index + 1)
                        z.decayLabel.set_text(str.tostring(health) + "%")
                    else
                        z.decayLabel.set_x(na)
                else
                    z.decayLabel.delete()

                z.wasHit := hit

                if hit or z.swept
                    z.lqEvaluateReversals(false, high, low, close, open, lqBarDelta, lqVol)
                    z.lqUpdateVisuals(false, lqShowSwept, lqBuyDeltaColor, lqSellDeltaColor, lqBslColor, lqSslColor)

color lqBarHighlight = na
if useLiquidity and activeTrades.size() > 0
    for i = activeTrades.size() - 1 to 0
        if i < activeTrades.size()
            LqTrade t = activeTrades.get(i)
            if t.active
                if bar_index > t.entryBar
                    bool inProfit = (t.dir == 1 and close > t.entry) or (t.dir == -1 and close < t.entry)
                    if inProfit
                        t.consecBars += 1
                        if na(lqBarHighlight) or lqBarHighlight == color.yellow
                            lqBarHighlight := color.aqua
                    else
                        t.consecBars := 0
                        if na(lqBarHighlight)
                            lqBarHighlight := color.yellow

                    if t.consecBars >= lqDashboardHold
                        t.active := false
                        t.won    := true
                    else if bar_index - t.entryBar >= lqDashboardWindow
                        t.active := false

                    if not t.active
                        if t.type == "ABS"
                            absTotal += 1
                            if t.won
                                absWins += 1
                        else if t.type == "EXH"
                            exhTotal += 1
                            if t.won
                                exhWins += 1
                        else if t.type == "DIV"
                            divTotal += 1
                            if t.won
                                divWins += 1
                        else if t.type == "REJ"
                            rejTotal += 1
                            if t.won
                                rejWins += 1
                        activeTrades.remove(i)

barcolor(useLiquidity and lqDashboardHilite ? lqBarHighlight : na)

if barstate.islast
    if useLiquidity and lqDashboard
        lqTable.merge_cells(0, 0, 3, 0)
        lqCell(lqTable, 0, 0, 'Reversal Performance (Time-Based)', txtColor=LQ_DATA, align=text.align_center)
        lqDivider(lqTable, 1, 3)
        lqCell(lqTable, 0, 2, 'Signal', txtColor=LQ_HEADERS, align=text.align_left)
        lqCell(lqTable, 1, 2, 'Total',  txtColor=LQ_HEADERS, align=text.align_right)
        lqCell(lqTable, 2, 2, 'Wins',   txtColor=LQ_HEADERS, align=text.align_right)
        lqCell(lqTable, 3, 2, 'Win %',  txtColor=LQ_HEADERS, align=text.align_right)
        lqDivider(lqTable, 3, 3)

        float absRate = absTotal > 0 ? (absWins / absTotal) * 100 : 0
        lqCell(lqTable, 0, 4, 'ABS', txtColor=LQ_DATA, align=text.align_left)
        lqCell(lqTable, 1, 4, str.tostring(absTotal), txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 2, 4, str.tostring(absWins),  txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 3, 4, str.tostring(absRate, '#.##') + '%', txtColor=absTotal > 0 ? (absRate >= 50 ? color.green : color.red) : LQ_DATA, align=text.align_right)
        lqDivider(lqTable, 5, 3)

        float exhRate = exhTotal > 0 ? (exhWins / exhTotal) * 100 : 0
        lqCell(lqTable, 0, 6, 'EXH', txtColor=LQ_DATA, align=text.align_left)
        lqCell(lqTable, 1, 6, str.tostring(exhTotal), txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 2, 6, str.tostring(exhWins),  txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 3, 6, str.tostring(exhRate, '#.##') + '%', txtColor=exhTotal > 0 ? (exhRate >= 50 ? color.green : color.red) : LQ_DATA, align=text.align_right)
        lqDivider(lqTable, 7, 3)

        float divRate = divTotal > 0 ? (divWins / divTotal) * 100 : 0
        lqCell(lqTable, 0, 8, 'DIV', txtColor=LQ_DATA, align=text.align_left)
        lqCell(lqTable, 1, 8, str.tostring(divTotal), txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 2, 8, str.tostring(divWins),  txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 3, 8, str.tostring(divRate, '#.##') + '%', txtColor=divTotal > 0 ? (divRate >= 50 ? color.green : color.red) : LQ_DATA, align=text.align_right)
        lqDivider(lqTable, 9, 3)

        float rejRate = rejTotal > 0 ? (rejWins / rejTotal) * 100 : 0
        lqCell(lqTable, 0, 10, 'REJ', txtColor=LQ_DATA, align=text.align_left)
        lqCell(lqTable, 1, 10, str.tostring(rejTotal), txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 2, 10, str.tostring(rejWins),  txtColor=LQ_DATA, align=text.align_right)
        lqCell(lqTable, 3, 10, str.tostring(rejRate, '#.##') + '%', txtColor=rejTotal > 0 ? (rejRate >= 50 ? color.green : color.red) : LQ_DATA, align=text.align_right)
    else
        lqTable.clear(0, 0, 3, 10)


