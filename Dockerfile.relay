FROM node:22-alpine
WORKDIR /app
COPY package.json package-lock.json* ./
RUN npm ci --omit=dev 2>/dev/null || npm install --omit=dev
COPY server.mjs trade-learnings.mjs trade-stats.mjs trade-insights.mjs trader-events.mjs relay-auth.mjs mexc-signer.mjs trade-context.mjs trader-config.mjs ./
EXPOSE 3002
ENV PORT=3002
ENV HOST=0.0.0.0
CMD ["node","server.mjs"]
