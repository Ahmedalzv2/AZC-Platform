{
  "name": "ict-autopilot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node server.mjs",
    "test": "TZ=UTC node --test --test-reporter=spec 'tests/*.test.mjs'",
    "test:watch": "TZ=UTC node --test --watch 'tests/*.test.mjs'",
    "dump-fixtures": "node tests/dump-fixtures.mjs",
    "eval": "node tests/eval-diff.mjs",
    "eval:bless": "node tests/eval-diff.mjs --bless",
    "insights": "node -e \"import('./trade-insights.mjs').then(m=>m.writeInsightsFile('./trade-learnings')).then(r=>console.log(r))\""
  }
}
